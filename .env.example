# Copy to .env and adjust for your environment.

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DB_NAME=inventory_db
DB_USER=inventory_user
DB_PASSWORD=inventory_pass
DB_HOST=localhost
DB_PORT=5432

# Email (password reset). Console backend used when DEBUG=True by default.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Inventory <no-reply@inventory.local>

# Low stock / reorder thresholds (global fallback)
LOW_STOCK_GLOBAL_THRESHOLD=10
